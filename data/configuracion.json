    "direccion": {
      "alias":         {"valor": "", "obligatorio": true,  "tipo": "texto",  "validadores": [], "msj_pedido": "🏠 Ingresá un nombre para esta dirección (ej: *Casa*, *Trabajo*):", "msj_reintento": "⚠️ El alias ingresado no es válido. Intentá nuevamente:"},
      "direccion":     {"valor": "", "obligatorio": true,  "tipo": "texto",  "validadores": [],  "msj_pedido": "🏠 Por favor ingresá tu *calle/dirección*:", "msj_reintento": "⚠️ La dirección ingresada no es válida. Intentá nuevamente:"},
      "altura":        {"valor": "", "obligatorio": true,  "tipo": "numero", "validadores": [], "msj_pedido": "🏠 Ingresá el *número de altura*:", "msj_reintento": "⚠️ La altura debe ser solo números. Intentá nuevamente:"},
      "piso":          {"valor": "", "obligatorio": false, "tipo": "texto",  "validadores": [], "msj_pedido": "🏠 Ingresá el *piso* (o '-' si no aplica):", "msj_reintento": ""},
      "depto":         {"valor": "", "obligatorio": false, "tipo": "texto",  "validadores": [], "msj_pedido": "🏠 Ingresá el *departamento* (o '-' si no aplica):", "msj_reintento": ""},
      "localidad":     {"valor": "", "obligatorio": true,  "tipo": "texto",  "validadores": [], "msj_pedido": "🏠 Ingresá tu *localidad*:", "msj_reintento": "⚠️ La localidad ingresada no es válida. Intentá nuevamente:"},
      "codigo_postal": {"valor": "", "obligatorio": true,  "tipo": "numero", "validadores": [], "msj_pedido": "🏠 Ingresá tu *código postal*:", "msj_reintento": "⚠️ El código postal debe ser solo números. Intentá nuevamente:"},
      "provincia":     {"valor": "", "obligatorio": true,  "tipo": "texto",  "validadores": [], "msj_pedido": "🏠 Ingresá tu *provincia*:", "msj_reintento": "⚠️ La provincia ingresada no es válida. Intentá nuevamente:"}
    }
  },

