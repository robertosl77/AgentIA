      "apellido":  {"valor": "", "obligatorio": true,  "tipo": "texto",    "validadores": ["texto_maximo_50"], "msj_pedido": "👤 Por favor ingresá tu *apellido*:", "msj_reintento": "⚠️ El apellido ingresado no es válido. Por favor ingresá solo letras:"},
